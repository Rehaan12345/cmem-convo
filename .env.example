# Copy this file to .env and fill in your API key.
# The app defaults to Claude. Set LLM_PROVIDER=openai to use GPT-4o instead.

LLM_PROVIDER=claude

# Anthropic (Claude) — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — only needed if LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
